            "body": {
              "mode": "raw",
              "raw": "{\n  \"collaboratorId\": \"1234567890\",\n  \"contractType\": \"FULL_TIME\",\n  \"startDate\": \"2024-01-01\",\n  \"endDate\": \"2025-01-01\",\n  \"salary\": 85000.00,\n  \"currency\": \"USD\",\n  \"termsAndConditions\": \"Standard employment contract with benefits\",\n  \"autoRenewal\": true,\n  \"noticePeriodDays\": 30\n}"
