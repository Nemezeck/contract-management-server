  "item": [
    {
      "name": "Collaborators",
      "item": [
        {
          "name": "Create Collaborator",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nationalId\": \"9876543210\",\n  \"employeeCode\": \"EMP006\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test.user@company.com\",\n  \"phone\": \"+1234567899\",\n  \"department\": \"Engineering\",\n  \"position\": \"Software Developer\",\n  \"status\": \"ACTIVE\",\n  \"hireDate\": \"2024-01-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/collaborators",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "collaborators"]
            }
          }
        },
        {
          "name": "Get All Collaborators",
          "request": {
            "method": "GET",
